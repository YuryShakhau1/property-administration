<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
           http://www.liquibase.org/xml/ns/dbchangelog
           http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Creates hotel -->
    <changeSet id="20260414-1" author="yury_shakhau">
        <createTable tableName="hotels">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="brand" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>

    </changeSet>

    <!-- Creates address -->
    <changeSet id="20260414-2" author="yury_shakhau">
        <createTable tableName="addresses">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="house_number" type="VARCHAR(20)"/>
            <column name="street" type="VARCHAR(100)"/>
            <column name="city" type="VARCHAR(50)"/>
            <column name="country" type="VARCHAR(50)"/>
            <column name="post_code" type="VARCHAR(20)"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="addresses"
                                 baseColumnNames="hotel_id"
                                 referencedTableName="hotels"
                                 referencedColumnNames="id"
                                 constraintName="fk_address_hotel"
                                 onDelete="CASCADE"/>

        <createIndex indexName="idx_address_hotel_id" tableName="addresses">
            <column name="hotel_id"/>
        </createIndex>
    </changeSet>

    <!-- Creates contacts -->
    <changeSet id="20260414-3" author="yury_shakhau">
        <createTable tableName="contacts">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="phone" type="VARCHAR(20)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="email" type="VARCHAR(256)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="contacts"
                                 baseColumnNames="hotel_id"
                                 referencedTableName="hotels"
                                 referencedColumnNames="id"
                                 constraintName="fk_contacts_hotel"
                                 onDelete="CASCADE"/>

        <createIndex indexName="idx_contacts_hotel_id" tableName="contacts">
            <column name="hotel_id"/>
        </createIndex>
    </changeSet>

    <!-- Creates arrival time -->
    <changeSet id="20260414-4" author="yury_shakhau">
        <createTable tableName="arrival_times">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="check_in" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="check_out" type="VARCHAR(256)"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="arrival_times"
                                 baseColumnNames="hotel_id"
                                 referencedTableName="hotels"
                                 referencedColumnNames="id"
                                 constraintName="fk_arrival_times_hotel"
                                 onDelete="CASCADE"/>

        <createIndex indexName="idx_arrival_times_hotel_id" tableName="arrival_times">
            <column name="hotel_id"/>
        </createIndex>
    </changeSet>

    <!-- Creates amenity -->
    <changeSet id="20260414-5" author="yury_shakhau">
        <createTable tableName="amenities">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="hotel_amenities">
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="amenity_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="hotel_amenities"
                                 baseColumnNames="hotel_id"
                                 constraintName="fk_hotel_amenity_hotel"
                                 referencedTableName="hotels"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <addForeignKeyConstraint baseTableName="hotel_amenities"
                                 baseColumnNames="amenity_id"
                                 constraintName="fk_hotel_amenity_amenity"
                                 referencedTableName="amenities"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <addUniqueConstraint tableName="hotel_amenities"
                             columnNames="hotel_id, amenity_id"
                             constraintName="uk_hotel_amenity"/>

        <createIndex indexName="idx_hotel_amenities_hotel_id"
                     tableName="hotel_amenities">
            <column name="hotel_id"/>
        </createIndex>

        <createIndex indexName="idx_hotel_amenities_amenity_id"
                     tableName="hotel_amenities">
            <column name="amenity_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>